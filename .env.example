APP_NAME="Ranco Autoshop"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
# For quick start, SQLite. Switch to MySQL for production.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=rancoautoshop
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Google Sign-In (Socialite) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Twilio WhatsApp OTP ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Midtrans ---
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# --- RajaOngkir ---
RAJAONGKIR_API_KEY=
RAJAONGKIR_BASE_URL=https://api.rajaongkir.com/starter
# Origin city id of your store. Common IDs:
#   470 = Kota Tasikmalaya  |  152 = Jakarta Pusat   |  78  = Kota Bekasi
#   22  = Kota Bandung      |  444 = Kota Surabaya   |  501 = Yogyakarta
RAJAONGKIR_ORIGIN_CITY_ID=470

# --- Komerce Collaborator API (preferred for go-live) ---
# When KOMERCE_ENABLED=true and both KOMERCE_API_KEY and
# KOMERCE_ORIGIN_DESTINATION_ID are set, ongkir is calculated live via
# Komerce. If any of these is missing, the system falls back to the legacy
# RajaOngkir endpoint (if RAJAONGKIR_API_KEY set) or to the curated mock.
#
# How to get values:
#   1. Sign up at https://collaborator.komerce.id and grab the
#      "Shipping Cost" API key (Settings → Developer → Settings).
#   2. Find your store's destination_id by hitting (with your key set):
#         GET /api/shipping/search-destination?q=Indihiang
#      and pick the row matching your kecamatan + zip code.
#   3. For production: switch BASE_URL to https://api.collaborator.komerce.id
#      and use a production-tier key (sandbox is rate-limited to 100/day).
KOMERCE_ENABLED=false
KOMERCE_API_KEY=
KOMERCE_BASE_URL=https://api-sandbox.collaborator.komerce.id
KOMERCE_ORIGIN_DESTINATION_ID=

# --- Admin bootstrap (used by seeder) ---
ADMIN_EMAIL=admin@rancoautoshop.local
ADMIN_PASSWORD=admin12345
ADMIN_NAME="Ranco Admin"
