# ==============================================================================
# Ranco Autoshop — Frontend ENV untuk PRODUCTION (Vercel atau host lain)
# ==============================================================================
# Cara pakai di Vercel:
#   Project Settings -> Environment Variables -> Add (Production scope).
#   Salin satu per satu key di bawah, isi value-nya.
#
# Cara pakai di VPS:
#   Salin file ini ke `.env.production`, isi value, lalu `npm run build && npm start`.
# ==============================================================================

# URL backend Laravel-nya (TANPA trailing slash). Next.js mem-proxy /api/* ke sini.
NEXT_PUBLIC_API_URL=https://api.rancoautoshop.com

# Midtrans CLIENT KEY (boleh dipublish di browser).
# - Sandbox: prefix `SB-Mid-client-...`
# - Production: tanpa prefix SB- (`Mid-client-...`)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-REPLACE_ME

# URL Snap.js
# - Sandbox: https://app.sandbox.midtrans.com/snap/snap.js
# - Production: https://app.midtrans.com/snap/snap.js
NEXT_PUBLIC_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js
