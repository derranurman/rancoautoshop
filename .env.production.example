# ==============================================================================
# Ranco Autoshop — TEMPLATE .env untuk HOSTING (sandbox-ready)
# ==============================================================================
# Cara pakai:
#   1. Salin file ini ke `.env` di hosting:
#        cp .env.production.example .env
#   2. Ganti semua placeholder `REPLACE_ME` dengan nilai sebenarnya.
#   3. Generate APP_KEY:    php artisan key:generate
#   4. Migrate + seed:      php artisan migrate --seed --force
#   5. Storage symlink:     php artisan storage:link
#
# Nilai Midtrans/RajaOngkir di bawah TETAP sandbox — sengaja. Saat siap go-live
# ke production beneran, lihat DEPLOY.md bagian "Saat siap go-live".
# ==============================================================================

APP_NAME="Ranco Autoshop"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.rancoautoshop.com
FRONTEND_URL=https://rancoautoshop.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ------------------------------------------------------------------------------
# Database — WAJIB MySQL/MariaDB. JANGAN pakai sqlite di production.
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=REPLACE_ME           # mis. localhost atau 127.0.0.1 untuk Niagahoster
DB_PORT=3306
DB_DATABASE=REPLACE_ME       # mis. ranco_prod
DB_USERNAME=REPLACE_ME
DB_PASSWORD=REPLACE_ME

# ------------------------------------------------------------------------------
# Session / Sanctum / CORS
# Pastikan SESSION_DOMAIN diawali titik supaya cookie bisa shared antar
# subdomain (api.* dan www.*). Tanpa ini, login admin akan looping.
# ------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.rancoautoshop.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=rancoautoshop.com,www.rancoautoshop.com
CORS_ALLOWED_ORIGINS=https://rancoautoshop.com,https://www.rancoautoshop.com

# ------------------------------------------------------------------------------
# Cache & Queue
# CACHE_STORE=database wajib supaya hasil RajaOngkir di-cache 6 jam dan tidak
# kena rate-limit setiap kali user buka checkout.
# ------------------------------------------------------------------------------
CACHE_STORE=database
QUEUE_CONNECTION=database

# ------------------------------------------------------------------------------
# Google Sign-In (opsional). Kosongkan jika belum dipakai.
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.rancoautoshop.com/api/auth/google/callback

# ------------------------------------------------------------------------------
# Twilio WhatsApp OTP (opsional). Tanpa kunci, OTP di-log ke laravel.log.
# ------------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ------------------------------------------------------------------------------
# Midtrans — TETAP SANDBOX untuk launch awal / staging / UAT.
# Saat go-live: ganti SERVER_KEY & CLIENT_KEY ke production (tanpa prefix SB-),
# IS_PRODUCTION=true, dan SNAP_URL ke app.midtrans.com.
# ------------------------------------------------------------------------------
MIDTRANS_SERVER_KEY=SB-Mid-server-REPLACE_ME
MIDTRANS_CLIENT_KEY=SB-Mid-client-REPLACE_ME
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# ------------------------------------------------------------------------------
# RajaOngkir — paket Starter (tier gratis). Hanya satu mode, tidak ada sandbox
# terpisah, jadi tidak perlu diganti saat go-live. Cukup ganti API key kalau
# upgrade ke Basic/Pro.
# ------------------------------------------------------------------------------
RAJAONGKIR_API_KEY=REPLACE_ME
RAJAONGKIR_BASE_URL=https://api.rajaongkir.com/starter
RAJAONGKIR_ORIGIN_CITY_ID=152

# ------------------------------------------------------------------------------
# Admin bootstrap (HANYA dipakai saat seed pertama kali). Setelah seed berhasil,
# wajib ganti password admin lewat menu Profil Admin di /admin.
# ------------------------------------------------------------------------------
ADMIN_EMAIL=admin@rancoautoshop.local
ADMIN_PASSWORD=GANTI_PASSWORD_INI_SETELAH_DEPLOY
ADMIN_NAME="Ranco Admin"
